# Database Configuration
# SQLite (default - no installation required)
DATABASE_URL=sqlite:///./finance_tracker.db

# PostgreSQL (optional - requires PostgreSQL installation)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_tracker

# Alternative format for different PostgreSQL setups:
# DATABASE_URL=postgresql://username:password@host:port/database_name

# Example for cloud PostgreSQL (like Heroku):
# DATABASE_URL=postgresql://user:pass@host.compute.amazonaws.com:5432/dbname
